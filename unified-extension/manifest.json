{
  "name": "Valmo Ops Assistant",
  "description": "Unified ops support with AI-powered chatbot. Auto-syncs from Google Sheets.",
  "version": "1.0",
  "manifest_version": 3,

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Valmo Ops",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },

  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "notifications"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://console.valmo.in/*",
        "https://*.kapturecrm.com/*",
        "http://localhost:3000/*"
      ],
      "css": [
        "styles/unified.css",
        "styles/process-pulse-enhanced.css",
        "styles/captain-process-overlay.css",
        "styles/captain-timer-notification.css",
        "styles/process-timer-tab.css",
        "styles/captain-pause-modal.css",
        "styles/captain-metrics-dashboard.css",
        "gamification/my-stats-tab.css",
        "tat-system/tat-dashboard.css"
      ],
      "js": [
        "config.js",
        "sheets-sync.js",
        "supabase-sync.js",
        "process-progress.js",
        "gamification/gamification-system.js",
        "gamification/my-stats-tab.js",
        "gamification/snooze-feature.js",
        "captain-process-overlay.js",
        "tat-system/tat-tracker-background.js",
        "tat-system/tat-analytics.js",
        "tat-system/tat-dashboard-ui.js",
        "tat-system/art-metrics-ui.js",
        "smart-chatbot.js",
        "content.js",
        "process-pulse-enhanced.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "host_permissions": [
    "https://valmostagging.kapturecrm.com/*",
    "https://console.valmo.in/*",
    "https://wfnmltorfvaokqbzggkn.supabase.co/*",
    "https://docs.google.com/*",
    "https://api.groq.com/*",
    "https://sheets.googleapis.com/*"

  ],

  "web_accessible_resources": [
    {
      "resources": [
        "data/log10_processes.json",
        "data/sop_database.json",
        "data/template_database.json",
        "data/*.mp4",
        "captain-timer-system.js",
        "captain-pause-modal.js",
        "process-timer-tab.js",
        "captain-metrics-dashboard.js"
      ],
      "matches": [
        "https://console.valmo.in/*",
        "https://*.kapturecrm.com/*"
      ]
    }
  ]
}